import os
import mysql.connector

# Railway database configuration (these will come from Render environment variables)
DB_CONFIG = {
    'host': os.environ.get('DB_HOST'),        # From Render env vars
    'database': os.environ.get('DB_NAME'),    # From Render env vars
    'user': os.environ.get('DB_USER'),        # From Render env vars
    'password': os.environ.get('DB_PASSWORD'),# From Render env vars
    'port': int(os.environ.get('DB_PORT', 3306))
}

def get_db_connection():
    try:
        connection = mysql.connector.connect(**DB_CONFIG)
        return connection
    except mysql.connector.Error as e:
        print(f"Database connection error: {e}")
        return None
